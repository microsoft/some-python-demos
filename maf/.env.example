# Azure OpenAI endpoint (from terraform output "openai_endpoint")
AZURE_OPENAI_ENDPOINT=https://oai-pydemos.openai.azure.com/

# Azure OpenAI deployment name (defaults to gpt-4o if not set)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Base URL for the FastAPI tickets demo (defaults to http://localhost:8000)
TICKETS_API_BASE=http://localhost:8000
